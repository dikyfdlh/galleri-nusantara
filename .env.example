# ---- Server ----
PORT=4000

# Set "production" saat deploy live (mengurangi log & mengaktifkan mode produksi).
NODE_ENV=development

# Lokasi penyimpanan data (database JSON & foto). Saat deploy ke hosting,
# arahkan ke folder VOLUME/DISK PERSISTEN agar data TIDAK HILANG saat redeploy.
# Kosongkan untuk default: server/data dan server/uploads.
# Contoh produksi (mis. volume di-mount ke /data):
#   DATA_DIR=/data
#   UPLOAD_DIR=/data/uploads
DATA_DIR=
UPLOAD_DIR=

# Password untuk masuk ke halaman /admin.
# WAJIB diganti sebelum dipakai sungguhan -- jangan biarkan "admin123".
ADMIN_PASSWORD=admin123

# Kunci rahasia server untuk menandatangani token admin (HMAC).
# Isi string acak panjang & rahasia. Bila dikosongkan, sistem memakai turunan
# dari password (kurang aman bila password masih default).
# Contoh buat acak: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=

# ====================================================================
#  PEMBAYARAN — pilih SALAH SATU mode di bawah ini
# ====================================================================
#
#  Prioritas: (1) Midtrans  ->  (2) QRIS statis  ->  (3) MODE DEMO
#
# -------- Mode 1: Midtrans (QRIS dinamis, KONFIRMASI OTOMATIS) --------
# Uang masuk ke rekening settlement merchant yang terdaftar di akun
# Midtrans (dicairkan ke rekening bank pemilik, biasanya T+1).
#
# Cara dapat key:
#   1. Daftar di https://dashboard.sandbox.midtrans.com (sandbox, gratis,
#      tanpa verifikasi bisnis) untuk uji coba.
#   2. Settings > Access Keys -> salin Server Key & Client Key.
#   3. Untuk PRODUKSI: lengkapi data bisnis + rekening pencairan di
#      dashboard.midtrans.com, lalu pakai Server Key produksi & set
#      MIDTRANS_IS_PRODUCTION=true.
#   4. (Opsional, untuk webhook) Settings > Configuration >
#      Payment Notification URL = https://DOMAIN-ANDA/api/webhook/midtrans
#      (tanpa webhook pun tetap jalan: server polling status Midtrans).
#
# Kosongkan PAYMENT_GATEWAY untuk menonaktifkan Midtrans.
PAYMENT_GATEWAY=midtrans
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# ---- QRIS (Mode 2 & 3 — dipakai bila Midtrans tidak aktif) ----
# Tempel STRING QRIS STATIS milik merchant Anda di sini (hasil decode QR statis dari
# bank/penyedia QRIS, diawali "00020101..."). Sistem akan mengubahnya menjadi QRIS
# DINAMIS dengan nominal yang ditentukan + CRC dihitung ulang otomatis.
# Jika dikosongkan, sistem memakai payload DEMO (QR tetap muncul & memuat nominal,
# tetapi tidak bisa dipakai bayar sungguhan).
QRIS_BASE_STRING=

# Nama merchant untuk payload DEMO (dipakai hanya bila QRIS_BASE_STRING kosong)
QRIS_MERCHANT_NAME=GALLERI NUSANTARA
QRIS_MERCHANT_CITY=KOTA CIMAHI

# Persentase DP (uang muka) default, 1-100
DEFAULT_DP_PERCENT=50
